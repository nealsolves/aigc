{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WorkflowArtifact",
  "type": "object",
  "required": [
    "workflow_schema_version",
    "artifact_type",
    "session_id",
    "status",
    "started_at",
    "steps",
    "invocation_audit_checksums"
  ],
  "properties": {
    "workflow_schema_version": {"type": "string"},
    "artifact_type": {"type": "string", "const": "workflow"},
    "session_id": {"type": "string"},
    "policy_file": {"type": ["string", "null"]},
    "status": {
      "type": "string",
      "enum": ["COMPLETED", "FAILED", "CANCELED", "INCOMPLETE"]
    },
    "started_at": {"type": "integer"},
    "finalized_at": {"type": ["integer", "null"]},
    "steps": {"type": "array"},
    "invocation_audit_checksums": {
      "type": "array",
      "items": {"type": "string"}
    },
    "failure_summary": {"type": ["object", "null"]},
    "approval_checkpoints": {
      "type": "array",
      "description": "Ordered record of pause/resume events with approval metadata",
      "items": {
        "type": "object",
        "properties": {
          "checkpoint_id": {"type": "string"},
          "paused_at": {"type": "integer"},
          "approver_id": {"type": ["string", "null"]},
          "reason": {"type": ["string", "null"]},
          "status": {"type": "string", "enum": ["pending", "approved", "denied"]},
          "resumed_at": {"type": ["integer", "null"]},
          "approval_note": {"type": ["string", "null"]},
          "denial_reason": {"type": ["string", "null"]}
        }
      }
    },
    "validator_hook_evidence": {
      "type": "array",
      "description": "Ordered record of ValidatorHook evaluation results for steps in this session",
      "items": {"type": "object"}
    },
    "metadata": {"type": "object"}
  },
  "additionalProperties": false
}
