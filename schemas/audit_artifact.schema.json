{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AIGC Audit Artifact",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "audit_schema_version": {
      "type": "string"
    },
    "policy_file": {
      "type": "string",
      "minLength": 1
    },
    "policy_schema_version": {
      "type": "string"
    },
    "policy_version": {
      "type": "string"
    },
    "model_provider": {
      "type": "string",
      "minLength": 1
    },
    "model_identifier": {
      "type": "string",
      "minLength": 1
    },
    "role": {
      "type": "string",
      "minLength": 1
    },
    "enforcement_result": {
      "type": "string",
      "enum": ["PASS", "FAIL"]
    },
    "failures": {
      "type": "array",
      "maxItems": 1000,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" },
          "field": { "type": ["string", "null"] }
        },
        "required": ["code", "message", "field"]
      }
    },
    "failure_gate": {
      "type": ["string", "null"],
      "enum": [null, "invocation_validation", "role_validation", "precondition_validation", "schema_validation", "postcondition_validation", "feature_not_implemented", "tool_validation", "guard_evaluation", "condition_resolution", "sink_emission", "risk_scoring", "custom_gate_violation", "wrapped_function_error"],
      "description": "Which enforcement gate failed (null for PASS results)"
    },
    "failure_reason": {
      "type": ["string", "null"],
      "description": "Human-readable failure reason (null for PASS results)"
    },
    "input_checksum": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "output_checksum": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "timestamp": {
      "type": "integer",
      "minimum": 0
    },
    "context": {
      "type": "object",
      "maxProperties": 100,
      "description": "Invocation context fields (e.g. session_id, tenant_id) for sink consumers"
    },
    "metadata": {
      "type": "object",
      "maxProperties": 100,
      "properties": {
        "enforcement_mode": {
          "type": "string",
          "enum": ["unified", "split", "split_pre_call_only"],
          "description": "Execution mode used for this artifact"
        },
        "pre_call_gates_evaluated": {
          "type": "array",
          "items": { "type": "string" },
          "maxItems": 1000,
          "description": "Ordered list of Phase A gates completed"
        },
        "post_call_gates_evaluated": {
          "type": "array",
          "items": { "type": "string" },
          "maxItems": 1000,
          "description": "Ordered list of Phase B gates completed"
        },
        "pre_call_timestamp": {
          "type": "integer",
          "minimum": 0,
          "description": "Unix epoch seconds when Phase A completed"
        },
        "post_call_timestamp": {
          "type": "integer",
          "minimum": 0,
          "description": "Unix epoch seconds when Phase B completed"
        }
      },
      "additionalProperties": true
    },
    "risk_score": {
      "type": ["number", "null"],
      "description": "Computed risk score from risk scoring engine"
    },
    "signature": {
      "type": ["string", "null"],
      "description": "Cryptographic signature of the artifact"
    },
    "provenance": {
      "type": ["object", "null"],
      "description": "Workflow provenance metadata supplied by the caller",
      "minProperties": 1,
      "properties": {
        "source_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1,
          "uniqueItems": true,
          "maxItems": 1000,
          "description": "Identifiers of source invocations that contributed to this one"
        },
        "derived_from_audit_checksums": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "minItems": 1,
          "uniqueItems": true,
          "maxItems": 1000,
          "description": "SHA-256 checksums of prior audit artifacts this invocation derived from"
        },
        "compilation_source_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$",
          "description": "Orchestrator-supplied hash of the raw source compilation set"
        }
      },
      "additionalProperties": false
    },
    "chain_id": {
      "type": ["string", "null"],
      "description": "Audit chain identifier for tamper-evident chaining"
    },
    "chain_index": {
      "type": ["integer", "null"],
      "description": "Position in the audit chain"
    },
    "previous_audit_checksum": {
      "type": ["string", "null"],
      "description": "SHA-256 checksum of the previous artifact in the chain"
    },
    "checksum": {
      "type": ["string", "null"],
      "description": "SHA-256 checksum of this artifact (populated by AuditChain to enable tamper detection of the last link)"
    }
  },
  "required": [
    "audit_schema_version",
    "policy_file",
    "policy_schema_version",
    "policy_version",
    "model_provider",
    "model_identifier",
    "role",
    "enforcement_result",
    "failures",
    "input_checksum",
    "output_checksum",
    "timestamp",
    "context",
    "metadata"
  ]
}
